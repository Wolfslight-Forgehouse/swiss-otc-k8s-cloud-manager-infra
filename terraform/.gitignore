# Terraform state (NEVER commit state files!)
*.tfstate
*.tfstate.*
*.tfstate.backup
tfplan*
.terraform/
.terraform.lock.hcl

# Variables with secrets
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
