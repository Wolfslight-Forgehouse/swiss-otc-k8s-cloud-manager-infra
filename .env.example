# Swiss OTC Cloud Manager — Environment Variables
# Copy to .env and fill in your values

# OTC Credentials (AK/SK)
OTC_ACCESS_KEY=
OTC_SECRET_KEY=
OTC_PROJECT_ID=
OTC_DOMAIN_NAME=    # e.g. OTC00000000001000000xxx
OTC_PROJECT_NAME=   # e.g. eu-ch2_myproject

# Cluster
RKE2_TOKEN=         # Generate: openssl rand -hex 32

# CI/CD (optional)
GH_PAT=             # GitHub PAT for runner registration
GHCR_PULL_TOKEN=    # GitHub PAT with read:packages
GITLAB_URL=         # e.g. https://gitlab.com
GITLAB_RUNNER_TOKEN=
